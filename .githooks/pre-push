#!/bin/bash
set -euo pipefail

# Pre-push syntax check for the claude-cortex skeleton.
# Install: git config core.hooksPath .githooks

export PYTHONUNBUFFERED=1

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

echo "[pre-push] Running syntax checks on Python files..."

if ! python3 -m compileall -q "$SCRIPT_DIR/plugins" "$SCRIPT_DIR/q-system" 2>&1; then
    echo "[pre-push] BLOCKED: Python syntax errors detected."
    exit 1
fi

echo "[pre-push] Python syntax OK. Push allowed."
